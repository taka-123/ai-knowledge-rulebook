{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "GOOGLE_GENAI_USE_GCA": "true"
  },
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/statusline-command.sh"
  },
  "model": "opusplan",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "~/.claude",
        "~/.claude/**",
        "~/.Trash",
        "~/.Trash/**",
        "~/.config",
        "~/.config/**",
        "~/.local/share/gomi",
        "~/.local/share/gomi/**",
        "~/.local/share/Trash",
        "~/.local/share/Trash/**",
        "/tmp",
        "/tmp/**",
        "~/.gemini",
        "~/.gemini/**",
        "~/.npm",
        "~/.npm/**",
        "~/.cache",
        "~/.cache/**",
        "~/.pnpm-store",
        "~/.pnpm-store/**",
        "~/.yarn",
        "~/.yarn/**",
        "~/.bun",
        "~/.bun/**",
        "~/Library/Caches",
        "~/Library/Caches/**"
      ],
      "denyRead": [
        "~/.claude.json",
        "~/.claude/.credentials.json",
        "~/.claude/.credentials*",
        "~/.ssh",
        "~/.ssh/**",
        "~/.aws",
        "~/.aws/**",
        "~/.gcp",
        "~/.gcp/**",
        "~/.docker",
        "~/.docker/**",
        "~/.kube",
        "~/.kube/**",
        "~/.gnupg",
        "~/.gnupg/**",
        "~/secrets",
        "~/secrets/**",
        "~/.gemini/oauth_creds.json",
        "~/.gemini/credentials.json",
        "~/.gemini/*token*",
        "~/.config/gcloud",
        "~/.config/gcloud/**",
        "~/.config/gh/hosts.yml"
      ],
      "denyWrite": [
        "~/.claude.json",
        "~/.claude/settings.json",
        "~/.claude/settings.local.json",
        "~/.claude/hooks",
        "~/.claude/hooks/**",
        "~/.claude/.credentials.json",
        "~/.claude/.credentials*",
        "~/.ssh",
        "~/.ssh/**",
        "~/.aws",
        "~/.aws/**",
        "~/.gcp",
        "~/.gcp/**",
        "~/.docker",
        "~/.docker/**",
        "~/.kube",
        "~/.kube/**",
        "~/.gnupg",
        "~/.gnupg/**",
        "~/secrets",
        "~/secrets/**",
        "~/.gemini/oauth_creds.json",
        "~/.gemini/credentials.json",
        "~/.gemini/*token*",
        "~/.config/gcloud",
        "~/.config/gcloud/**",
        "~/.config/gh/hosts.yml",
        "~/.zshrc",
        "~/.zshenv",
        "~/.zprofile",
        "~/.bashrc",
        "~/.bash_profile",
        "~/.bash_login",
        "~/.profile",
        "~/.config/fish/config.fish",
        "~/.gitconfig",
        "~/.config/git",
        "~/.config/git/**",
        "~/.npmrc",
        "~/.yarnrc",
        "~/.yarnrc.yml",
        "~/.pypirc",
        "~/.netrc",
        "~/Library/LaunchAgents",
        "~/Library/LaunchAgents/**",
        "/etc",
        "/etc/**",
        "/bin",
        "/bin/**",
        "/sbin",
        "/sbin/**",
        "/usr/bin",
        "/usr/bin/**",
        "/usr/sbin",
        "/usr/sbin/**",
        "/usr/local/bin",
        "/usr/local/bin/**",
        "/usr/local/sbin",
        "/usr/local/sbin/**",
        "/opt/homebrew/bin",
        "/opt/homebrew/bin/**",
        "/opt/homebrew/sbin",
        "/opt/homebrew/sbin/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "*.githubusercontent.com",
        "objects.githubusercontent.com",
        "release-assets.githubusercontent.com",
        "codeload.github.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "pypi.python.org",
        "files.pythonhosted.org",
        "fonts.gstatic.com",
        "fonts.googleapis.com",
        "cdn.jsdelivr.net",
        "unpkg.com",
        "cdnjs.cloudflare.com",
        "esm.sh",
        "playwright.azureedge.net",
        "playwright.download.prss.microsoft.com",
        "cdn.playwright.dev",
        "developer.mozilla.org",
        "docs.python.org",
        "nodejs.org",
        "code.claude.com",
        "docs.claude.com",
        "*.googleapis.com",
        "generativelanguage.googleapis.com",
        "api.google.com",
        "accounts.google.com",
        "oauth2.googleapis.com",
        "ocsp.digicert.com",
        "crl3.digicert.com",
        "crl4.digicert.com",
        "localhost",
        "127.0.0.1"
      ],
      "allowLocalBinding": true
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Read(secrets)",
      "Read(secrets/**)",
      "Read(**/secrets)",
      "Read(**/secrets/**)",
      "Edit(secrets)",
      "Edit(secrets/**)",
      "Edit(**/secrets)",
      "Edit(**/secrets/**)",
      "Write(secrets)",
      "Write(secrets/**)",
      "Write(**/secrets)",
      "Write(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Read(~/.claude.json)",
      "Write(~/.claude.json)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.claude/.credentials*)",
      "Write(~/.claude/.credentials.json)",
      "Write(~/.claude/.credentials*)",
      "Edit(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials*)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.local.json)",
      "Write(~/.claude/settings.local.json)",
      "Edit(~/.claude/hooks/**)",
      "Write(~/.claude/hooks/**)",
      "Read(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Write(~/.aws/**)",
      "Read(~/.gcp/**)",
      "Write(~/.gcp/**)",
      "Read(~/.docker/**)",
      "Write(~/.docker/**)",
      "Read(~/.kube/**)",
      "Write(~/.kube/**)",
      "Read(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Read(~/.gemini/oauth_creds.json)",
      "Read(~/.gemini/credentials.json)",
      "Read(~/.gemini/*token*)",
      "Write(~/.gemini/oauth_creds.json)",
      "Write(~/.gemini/credentials.json)",
      "Write(~/.gemini/*token*)",
      "Edit(~/.gemini/oauth_creds.json)",
      "Edit(~/.gemini/credentials.json)",
      "Edit(~/.gemini/*token*)",
      "Read(~/.config/gcloud/**)",
      "Write(~/.config/gcloud/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Write(~/.config/gh/hosts.yml)",
      "Write(~/.zshrc)",
      "Write(~/.zshenv)",
      "Write(~/.zprofile)",
      "Write(~/.bashrc)",
      "Write(~/.bash_profile)",
      "Write(~/.bash_login)",
      "Write(~/.profile)",
      "Write(~/.config/fish/config.fish)",
      "Write(~/.gitconfig)",
      "Write(~/.config/git/**)",
      "Write(~/.npmrc)",
      "Write(~/.yarnrc)",
      "Write(~/.yarnrc.yml)",
      "Write(~/.pypirc)",
      "Write(~/.netrc)",
      "Bash(sudo *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(export *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(base64 *)",
      "Bash(gh auth token *)",
      "Bash(gcloud auth print-access-token *)",
      "Bash(aws configure export-credentials *)"
    ],
    "allow": [
      "WebSearch",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(which *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(jq *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull)",
      "Bash(git branch *)",
      "mcp__pencil"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash $HOME/.claude/hooks/pretooluse_guard.sh" },
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [{ "type": "command", "command": "bash $HOME/.claude/hooks/validate-webfetch.sh" }]
      }
    ]
  }
}
